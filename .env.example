TELEGRAM_BOT_TOKEN=123456:replace-me
# 可选：允许使用机器人的 Telegram 用户 ID，多个 ID 用英文逗号分隔；留空表示所有能找到机器人的人都能使用。
TELEGRAM_ALLOWED_USER_IDS=
# 可选：Telegram Bot API 代理地址。host 网络模式下 Clash 常用 http://127.0.0.1:7890；bridge 网络可尝试 http://host.docker.internal:7890。
# 这里建议只代理 Telegram，不要给整个容器设置 HTTP_PROXY，避免 CloudDrive2 gRPC 也走代理。
TELEGRAM_PROXY_URL=
# 可选：Telegram 出站请求（发送/编辑消息）的 httpx 连接池大小与池等待超时（秒）。
# 自定义 bot 实例会绕过 python-telegram-bot 的默认大池，退回到池大小 1、池超时 1 秒，
# 代理慢时一条消息占住唯一连接就会导致 PoolTimeout、消息卡住。默认放大到 8 / 20 秒。
TELEGRAM_POOL_SIZE=8
TELEGRAM_POOL_TIMEOUT_SECS=20
# 可选：磁力搜索站点（境外站）的代理地址。默认留空时会自动复用上面的 TELEGRAM_PROXY_URL，
# 让 cili 也走代理，避免直连被墙/绕路导致搜索很慢。如果想让 cili 走另一条代理，单独填这里。
CILI_PROXY_URL=

# 推荐使用 CloudDrive2 API Token。提交离线下载至少需要 allow_add_offline_download 权限。
CLOUDDRIVE_API_TOKEN=

# 如果不用 API Token，可以让机器人用 CloudDrive2 账号密码获取 JWT；仍然更推荐 API Token。
CLOUDDRIVE_USERNAME=
CLOUDDRIVE_PASSWORD=
CLOUDDRIVE_TOTP_CODE=

# CloudDrive2 原生 gRPC 地址。优先使用直连 host:port，不要填普通网页反代地址。
# Docker Desktop 的 Windows/macOS 环境下，host.docker.internal 通常可以访问宿主机上的 CloudDrive2。
# 如果 CloudDrive2 在局域网其他机器上，建议填 内网IP:19798。
# 例如 CloudDrive2 在 192.168.1.2 上，就填 192.168.1.2:19798，并保持 CLOUDDRIVE_GRPC_TLS=false。
CLOUDDRIVE_GRPC_ADDR=host.docker.internal:19798
# CloudDrive2 gRPC 是否启用 TLS；如果地址写了 https:// 会自动启用，这里主要用于 host:port 写法。
# 如果使用 Lucky 等反代：只有机器人连到反代入口本身是 HTTPS/gRPC TLS 时才填 true。
# 如果 Lucky 后端转发到 CloudDrive2 原生 gRPC 端口，通常是明文，后端“使用安全连接”不要开启。
CLOUDDRIVE_GRPC_TLS=false
# 离线下载保存到 CloudDrive2 中的目标目录，必须是以 / 开头的绝对路径。
CLOUDDRIVE_DEST_FOLDER=/
# 目标目录不存在时是否自动创建；API Token 需要额外拥有 allow_create_folder 权限。
CLOUDDRIVE_AUTO_CREATE_DEST_FOLDER=true
# 提交任务后多少秒检查目标目录；0 表示不检查。
CLOUDDRIVE_CHECK_FOLDER_AFTER_SECS=10

# 磁力搜索站点地址。多个备用域名用英文逗号分隔，前一个 403/5xx 时会自动尝试下一个。
CILI_BASE_URLS=https://xcili.net,https://1cili.net,https://cili.info,https://cili.uk,https://wuji.me
# 每次搜索最多返回多少条结果，程序内部限制为 1 到 20。
MAX_SEARCH_RESULTS=8
# 访问搜索站点的 HTTP 超时时间，单位秒。
HTTP_TIMEOUT_SECS=15
# 单个磁力站点失败时的重试次数（仅对超时、连接错误、429、5xx 重试；403/404 不重试）。
# 重试会用更短的超时以控制总耗时。0 表示不重试。
CILI_MAX_RETRIES=2
# 重试退避基数，单位秒；第 n 次重试等待 retry_backoff * 2^(n-1) 秒。
CILI_RETRY_BACKOFF_SECS=1
# 日志级别，例如 DEBUG、INFO、WARNING、ERROR。
LOG_LEVEL=INFO

# ---- Telegram 轮询 / 自愈（解决“过夜后收不到消息”的问题）----
# getUpdates 长轮询超时（秒）。设小一点让客户端定期断开重连，避开代理空闲超时掐断隧道。范围建议 10~30，不要超过 50（Telegram 上限）。
POLLING_TIMEOUT_SECS=20
# httpx 连接 / 读取超时（秒）。读取超时必须大于上面的长轮询超时，否则会被误判为超时失败。
POLLING_CONNECT_TIMEOUT_SECS=10
POLLING_READ_TIMEOUT_SECS=60
# 连续多少次轮询失败就强制退出，让 Docker（restart: unless-stopped）重启拉起新连接。
POLLING_MAX_FAILURES=5
# 超过多少秒没有任何一次成功轮询就强制退出（兜底防“假活”）。
POLLING_STALENESS_SECS=300
